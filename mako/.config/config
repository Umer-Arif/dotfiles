# Take a look at the mako manpage with the command:
#   man 5 mako
# To view all configuration options.

# Fonts & Formats (Updated to your clean Inter UI Font)
font=Inter 11
format=<b>%a ⏵</b> %s\n%b
sort=-time
layer=overlay

# Desktop Placement Layout
# Removed hardcoded output=DP-2 so notifications work cleanly across any monitor setup in Niri
anchor=top-right
width=320
height=110
margin=15
padding=12

# Arc-Dark Base Theme Styling
background-color=#2f343f
text-color=#f3f4f5
border-size=2
border-color=#5294e2
border-radius=8

# Icons & Handlers
icons=1
max-icon-size=48
default-timeout=5000
ignore-timeout=1

# Context Custom Profiles (Urgency Theme Mappings)
[urgency=normal]
border-color=#5294e2

[urgency=high]
border-color=#e54c4c
default-timeout=0

[app-name=lightcord]
border-color=#5294e2

[summary~="log-.*"]
border-color=#a3be8c

[app-name=lightcord summary~="(.*(^| )orz|ORZ|sto|STO|otl|OTL( |$).*)"]
invisible=1
